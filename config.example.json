{
  "_comment": "Tushare MCP Server 配置文件示例",
  "_comment_usage": "复制此文件为 config.json 并根据需要修改",

  "host": "0.0.0.0",
  "port": 8080,
  "transport": "http",

  "services": {
    "all": {
      "name": "all",
      "path": "/",
      "description": "All Tushare APIs (stock, bond, fund, etf, index, hk_stock, us_stock)",
      "categories": [],
      "auth": {
        "type": "apikey",
        "required": true
      }
    },

    "stock": {
      "name": "stock",
      "path": "/stock",
      "description": "股票市场数据API - 包含基础数据、行情、财务等",
      "categories": [
        "stock_basic",
        "stock_market",
        "stock_financial",
        "stock_board",
        "stock_feature",
        "stock_fund_flow",
        "stock_margin",
        "stock_reference"
      ],
      "auth": {
        "type": "none",
        "required": true
      }
    },

    "bond": {
      "name": "bond",
      "path": "/bond",
      "description": "债券市场数据API",
      "categories": ["bond"],
      "auth": {
        "type": "none",
        "required": true
      }
    },

    "fund": {
      "name": "fund",
      "path": "/fund",
      "description": "基金市场数据API",
      "categories": ["fund"],
      "auth": {
        "type": "apikey",
        "required": true
      }
    },

    "index": {
      "name": "index",
      "path": "/index",
      "description": "指数数据API",
      "categories": ["index"],
      "auth": {
        "type": "apikey",
        "required": true
      }
    },

    "hk_stock": {
      "name": "hk_stock",
      "path": "/hk_stock",
      "description": "港股数据API",
      "categories": ["hk_stock"],
      "auth": {
        "type": "apikey",
        "required": true
      }
    },

    "us_stock": {
      "name": "us_stock",
      "path": "/us_stock",
      "description": "美股数据API",
      "categories": ["us_stock"],
      "auth": {
        "type": "apikey",
        "required": true
      }
    },

    "etf": {
      "name": "etf",
      "path": "/etf",
      "description": "ETF数据API",
      "categories": ["etf"],
      "auth": {
        "type": "apikey",
        "required": true
      }
    }
  },

  "global_auth": {
    "type": "none",
    "required": false
  },

  "api_tokens": [
    "your-tushare-token-1",
    "your-tushare-token-2"
  ],

  "logging": {
    "_comment": "日志配置",
    "level": "info",
    "_comment_level": "日志级别: debug, info, warn, error",
    "format": "json",
    "_comment_format": "日志格式: json (结构化) 或 text (纯文本)",
    "filename": "logs/tushare-mcp.log",
    "_comment_filename": "日志文件路径，空字符串表示输出到标准输出",
    "max_size": 100,
    "_comment_max_size": "单个日志文件最大大小(MB)",
    "max_age": 7,
    "_comment_max_age": "日志文件保留天数",
    "max_backups": 3,
    "_comment_max_backups": "保留的旧日志文件数量",
    "compress": true,
    "_comment_compress": "是否压缩旧的日志文件"
  }
}