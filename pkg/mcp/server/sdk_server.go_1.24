//go:build go1.24
// +build go1.24

package server

import (
	"context"
	"fmt"
	"log"
	"os"

	"github.com/chenniannian90/tushare-go/pkg/mcp"
	"github.com/chenniannian90/tushare-go/pkg/sdk"
	"github.com/modelcontextprotocol/go-sdk/mcp"
)

// SDKMCPServer implements an MCP server using the official MCP SDK
// 此实现需要 Go 1.24+ 版本
type SDKMCPServer struct {
	Registry       *mcp.ToolRegistry
	Health         *HealthManager
	Lifecycle      *LifecycleManager
	Config         *ServerConfig
	MCPServer      *mcp.Server
}

// NewSDKMCPServer creates a new MCP server using the official SDK
func NewSDKMCPServer(client *sdk.Client, config *ServerConfig) *SDKMCPServer {
	// Create tool registry with client
	toolRegistry := mcp.NewToolRegistry(client)

	// Create MCP server using official SDK
	server := mcp.NewServer(&mcp.Implementation{
		Name:    "tushare-mcp-server",
		Version: "1.0.0",
	}, &mcp.ServerOptions{})

	return &SDKMCPServer{
		Registry:  toolRegistry,
		Health:    NewHealthManager(),
		Lifecycle: NewLifecycleManager(),
		Config:    config,
		MCPServer: server,
	}
}

// StartStdio starts the MCP server using stdio transport
func (s *SDKMCPServer) StartStdio(ctx context.Context) error {
	// Setup logging
	logLevel := os.Getenv("LOG_LEVEL")
	if logLevel == "" {
		logLevel = "INFO"
	}
	SetupLogging(logLevel)

	log.Printf("Starting Tushare MCP Server (using official SDK)...")

	// Validate config
	if err := s.Config.Validate(); err != nil {
		log.Printf("Warning: %v", err)
	}

	info := GetServerInfo()
	LogStartup(s.Config, info)

	// Register tools from registry
	s.registerTools()

	// Create stdio transport
	transport := &mcp.StdioTransport{}

	// Start server
	log.Printf("MCP server running on stdio transport")

	// Handle authentication if required
	if s.Config.RequireAuth {
		log.Printf("API Key authentication enabled")
	}

	return s.MCPServer.Run(ctx, transport)
}

// StartHTTP starts the MCP server using HTTP transport with SSE
func (s *SDKMCPServer) StartHTTP(ctx context.Context, addr string) error {
	// Setup logging
	logLevel := s.Config.LogLevel
	if logLevel == "" {
		logLevel = "INFO"
	}
	SetupLogging(logLevel)

	log.Printf("Starting Tushare MCP HTTP Server (using official SDK)...")

	// Validate config
	if err := s.Config.Validate(); err != nil {
		return fmt.Errorf("configuration validation failed: %w", err)
	}

	info := GetServerInfo()
	LogStartup(s.Config, info)

	// Register tools from registry
	s.registerTools()

	// Create SSE server transport
	transport := &mcp.SSEServerTransport{
		Addr: addr,
	}

	// Start server
	log.Printf("MCP HTTP server listening on %s", addr)

	// Handle authentication if required
	if s.Config.RequireAuth {
		log.Printf("API Key authentication enabled")
	}

	return s.MCPServer.Run(ctx, transport)
}

// registerTools registers all tools from the registry with the MCP server
func (s *SDKMCPServer) registerTools() {
	tools := s.Registry.GetTools()
	log.Printf("Registering %d tools with MCP server:", len(tools))

	for _, tool := range tools {
		toolName := tool.Name

		// Create a closure to capture the tool name
		handler := func(ctx context.Context, req *mcp.CallToolRequest) (*mcp.CallToolResult, error) {
			// Extract arguments
			var args map[string]interface{}
			if req.Params.Arguments != nil {
				args = req.Params.Arguments
			} else {
				args = make(map[string]interface{})
			}

			log.Printf("Calling tool: %s with args: %v", toolName, args)

			// Record request
			s.Health.RecordRequest()

			// Call the tool via registry
			result, err := s.Registry.CallTool(ctx, toolName, args)
			if err != nil {
				s.Health.RecordError()
				return nil, fmt.Errorf("tool execution failed: %w", err)
			}

			// Convert result to MCP content format
			content := make([]mcp.Content, 0, len(result.Content))
			for _, c := range result.Content {
				switch c.Type {
				case "text":
					content = append(content, &mcp.TextContent{
						Type: "text",
						Text: c.Text,
					})
				default:
					// For other content types, use text content
					content = append(content, &mcp.TextContent{
						Type: "text",
						Text: c.Text,
					})
				}
			}

			return &mcp.CallToolResult{
				Content: content,
			}, nil
		}

		// Add tool to MCP server with generic handler
		mcp.AddTool(s.MCPServer, &mcp.Tool{
			Name:        tool.Name,
			Description: tool.Description,
			// Input schema can be added here if needed
		}, handler)

		log.Printf("  - %s: %s", tool.Name, tool.Description)
	}
}

// GetMCPServer returns the underlying MCP server instance
func (s *SDKMCPServer) GetMCPServer() *mcp.Server {
	return s.MCPServer
}

// GetStatus returns the current status of the server
func (s *SDKMCPServer) GetStatus() map[string]interface{} {
	status := s.Health.GetStatus(len(s.Registry.GetTools()))

	// Add SDK-specific information
	status["sdk_version"] = "official-go-sdk"
	status["server_type"] = "sdk-based"

	return status
}

// Stop gracefully stops the server
func (s *SDKMCPServer) Stop(ctx context.Context) error {
	log.Println("Stopping MCP server...")

	// The official SDK handles shutdown through context cancellation
	// This method is provided for API compatibility
	return nil
}