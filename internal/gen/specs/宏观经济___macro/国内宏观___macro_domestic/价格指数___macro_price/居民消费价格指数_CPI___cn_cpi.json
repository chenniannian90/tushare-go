{
  "api_name": "居民消费价格指数（CPI）",
  "api_code": "cn_cpi",
  "description": "获取CPI居民消费价格数据，包括全国、城市和农村的数据",
  "__describe__": {
    "url": "https://tushare.pro/document/2?doc_id=228",
    "name": "居民消费价格指数（CPI）",
    "category": "价格指数___macro_price"
  },
  "request_params": [
    {
      "name": "m",
      "type": "str",
      "description": "月份（YYYYMM，下同），支持多个月份同时输入，逗号分隔",
      "required": false
    },
    {
      "name": "start_m",
      "type": "str",
      "description": "开始月份",
      "required": false
    },
    {
      "name": "end_m",
      "type": "str",
      "description": "结束月份",
      "required": false
    }
  ],
  "response_fields": [
    {
      "name": "month",
      "type": "str",
      "description": "月份YYYYMM",
      "default_display": true
    },
    {
      "name": "nt_val",
      "type": "float",
      "description": "全国当月值",
      "default_display": true
    },
    {
      "name": "nt_yoy",
      "type": "float",
      "description": "全国同比（%）",
      "default_display": true
    },
    {
      "name": "nt_mom",
      "type": "float",
      "description": "全国环比（%）",
      "default_display": true
    },
    {
      "name": "nt_accu",
      "type": "float",
      "description": "全国累计值",
      "default_display": true
    },
    {
      "name": "town_val",
      "type": "float",
      "description": "城市当月值",
      "default_display": true
    },
    {
      "name": "town_yoy",
      "type": "float",
      "description": "城市同比（%）",
      "default_display": true
    },
    {
      "name": "town_mom",
      "type": "float",
      "description": "城市环比（%）",
      "default_display": true
    },
    {
      "name": "town_accu",
      "type": "float",
      "description": "城市累计值",
      "default_display": true
    },
    {
      "name": "cnt_val",
      "type": "float",
      "description": "农村当月值",
      "default_display": true
    },
    {
      "name": "cnt_yoy",
      "type": "float",
      "description": "农村同比（%）",
      "default_display": true
    },
    {
      "name": "cnt_mom",
      "type": "float",
      "description": "农村环比（%）",
      "default_display": true
    },
    {
      "name": "cnt_accu",
      "type": "float",
      "description": "农村累计值",
      "default_display": true
    }
