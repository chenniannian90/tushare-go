      "default_display": true
    },
    {
      "name": "close",
      "type": "float",
      "description": "现价",
      "default_display": true
    },
    {
      "name": "pre_close",
      "type": "float",
      "description": "昨收",
      "default_display": true
    },
    {
      "name": "high",
      "type": "float",
      "description": "最高价",
      "default_display": true
    },
    {
      "name": "open",
      "type": "float",
      "description": "开盘价",
      "default_display": true
    },
    {
      "name": "low",
      "type": "float",
      "description": "最低价",
      "default_display": true
    },
    {
      "name": "vol",
      "type": "float",
      "description": "成交量",
      "default_display": true
    },
    {
      "name": "amount",
      "type": "float",
      "description": "成交金额（元）",
      "default_display": true
    }
  ]
