{
  "api_name": "指数实时日线",
  "api_code": "rt_idx_k",
  "description": "获取交易所指数实时日线行情，支持按代码或代码通配符一次性提取全部交易所指数实时日k线行情",
  "__describe__": {
    "url": "https://tushare.pro/document/2?doc_id=403",
    "name": "指数实时日线",
    "category": "指数专题___index"
  },
  "request_params": [
    {
      "name": "ts_code",
      "type": "str",
      "description": "指数代码，支持通配符方式，e.g. 0*.SH、3*.SZ、000001.SH",
      "required": true
    }
  ],
  "response_fields": [
    {
      "name": "ts_code",
      "type": "str",
      "description": "指数代码",
