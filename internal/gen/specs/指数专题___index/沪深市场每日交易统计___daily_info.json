{
  "api_name": "沪深市场每日交易统计",
  "api_code": "daily_info",
  "description": "获取交易所股票交易统计，包括各板块明细",
  "__describe__": {
    "url": "https://tushare.pro/document/2?doc_id=215",
    "name": "沪深市场每日交易统计",
    "category": "指数专题___index"
  },
  "request_params": [
    {
      "name": "trade_date",
      "type": "str",
      "description": "交易日期（YYYYMMDD格式，下同）",
      "required": false
    },
    {
      "name": "ts_code",
      "type": "str",
      "description": "板块代码（请参阅下方列表）",
      "required": false
    },
    {
      "name": "exchange",
      "type": "str",
      "description": "股票市场（SH上交所 SZ深交所）",
      "required": false
    },
    {
      "name": "start_date",
      "type": "str",
      "description": "开始日期",
      "required": false
    },
    {
      "name": "end_date",
      "type": "str",
      "description": "结束日期",
      "required": false
    },
    {
      "name": "fields",
      "type": "str",
      "description": "指定提取字段",
      "required": false
    }
  ],
  "response_fields": [
    {
      "name": "trade_date",
      "type": "str",
      "description": "交易日期",
      "default_display": true
    },
    {
      "name": "ts_code",
      "type": "str",
      "description": "市场代码",
      "default_display": true
    },
    {
      "name": "ts_name",
      "type": "str",
      "description": "市场名称",
      "default_display": true
    },
    {
      "name": "com_count",
      "type": "int",
      "description": "挂牌数",
      "default_display": true
    },
    {
      "name": "total_share",
      "type": "float",
      "description": "总股本（亿股）",
      "default_display": true
    },
    {
      "name": "float_share",
      "type": "float",
      "description": "流通股本（亿股）",
      "default_display": true
    },
    {
      "name": "total_mv",
      "type": "float",
      "description": "总市值（亿元）",
      "default_display": true
    },
    {
      "name": "float_mv",
      "type": "float",
      "description": "流通市值（亿元）",
      "default_display": true
    },
    {
      "name": "amount",
      "type": "float",
      "description": "交易金额（亿元）",
      "default_display": true
    },
    {
      "name": "vol",
      "type": "float",
      "description": "成交量（亿股）",
      "default_display": true
    },
    {
      "name": "trans_count",
      "type": "int",
      "description": "成交笔数（万笔）",
      "default_display": true
    },
    {
      "name": "pe",
      "type": "float",
      "description": "平均市盈率",
      "default_display": true
    },
    {
      "name": "tr",
      "type": "float",
      "description": "换手率（％），注：深交所暂无此列",
      "default_display": true
    },
    {
      "name": "exchange",
      "type": "str",
      "description": "交易所（SH上交所 SZ深交所）",
      "default_display": true
    }
  ]
}