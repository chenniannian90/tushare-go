{
  "api_name": "合约信息",
  "api_code": "fut_basic",
  "description": "获取期货合约列表数据",
  "__describe__": {
    "url": "https://tushare.pro/document/2?doc_id=135",
    "name": "合约信息",
    "category": "期货数据___futures"
  },
  "request_params": [
    {
      "name": "exchange",
      "type": "str",
      "description": "交易所代码 CFFEX-中金所 DCE-大商所 CZCE-郑商所 SHFE-上期所 INE-上海国际能源交易中心 GFEX-广州期货交易所",
      "required": true
    },
    {
      "name": "fut_type",
      "type": "str",
      "description": "合约类型 (1 普通合约 2主力与连续合约 默认取全部)",
      "required": false
    },
    {
      "name": "fut_code",
      "type": "str",
      "description": "标准合约代码，如白银AG、AP鲜苹果等",
      "required": false
    },
    {
      "name": "list_date",
      "type": "str",
      "description": "上市开始日期(格式YYYYMMDD，从某日开始以来所有合约）",
      "required": false
    }
  ],
  "response_fields": [
    {
      "name": "ts_code",
      "type": "str",
      "description": "合约代码",
      "default_display": true
    },
    {
      "name": "symbol",
      "type": "str",
      "description": "交易标识",
      "default_display": true
    },
    {
      "name": "exchange",
      "type": "str",
      "description": "交易市场",
      "default_display": true
    },
    {
      "name": "name",
      "type": "str",
      "description": "中文简称",
      "default_display": true
    },
    {
      "name": "fut_code",
      "type": "str",
      "description": "合约产品代码",
      "default_display": true
    },
    {
      "name": "multiplier",
      "type": "float",
      "description": "合约乘数(只适用于国债期货、指数期货)",
      "default_display": true
    },
    {
      "name": "trade_unit",
      "type": "str",
      "description": "交易计量单位",
      "default_display": true
    },
    {
      "name": "per_unit",
      "type": "float",
      "description": "交易单位(每手)",
      "default_display": true
    },
    {
      "name": "quote_unit",
      "type": "str",
      "description": "报价单位",
      "default_display": true
    },
    {
      "name": "quote_unit_desc",
      "type": "str",
      "description": "最小报价单位说明",
      "default_display": true
    },
    {
      "name": "d_mode_desc",
      "type": "str",
      "description": "交割方式说明",
      "default_display": true
    },
    {
      "name": "list_date",
      "type": "str",
      "description": "上市日期",
      "default_display": true
    },
    {
      "name": "delist_date",
      "type": "str",
      "description": "最后交易日期",
      "default_display": true
    },
    {
      "name": "d_month",
      "type": "str",
      "description": "交割月份",
      "default_display": true
    },
    {
      "name": "last_ddate",
      "type": "str",
      "description": "最后交割日",
      "default_display": true
    },
    {
      "name": "trade_time_desc",
      "type": "str",
      "description": "交易时间说明",
      "default_display": false
    }
  ]
}