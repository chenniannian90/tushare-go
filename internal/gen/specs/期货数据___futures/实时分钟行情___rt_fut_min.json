{
  "api_name": "实时分钟行情",
  "api_code": "rt_fut_min",
  "description": "获取全市场期货合约实时分钟数据，支持1min/5min/15min/30min/60min行情，提供Python SDK、 http Restful API和websocket三种方式，如果需要主力合约分钟，请先通过主力mapping接口获取对应的合约代码后提取分钟。",
  "__describe__": {
    "url": "https://tushare.pro/document/2?doc_id=340",
    "name": "实时分钟行情",
    "category": "期货数据___futures"
  },
  "request_params": [
    {
      "name": "ts_code",
      "type": "str",
      "description": "股票代码，e.g.CU2310.SHF，仅支持一次一个合约的回放",
      "required": true
    },
    {
      "name": "freq",
      "type": "str",
      "description": "分钟频度（1MIN/5MIN/15MIN/30MIN/60MIN）",
      "required": true
    },
    {
      "name": "date_str",
      "type": "str",
      "description": "回放日期（格式：YYYY-MM-DD，默认为交易当日，支持回溯一天）",
      "required": false
    }
  ],
  "response_fields": [
    {
      "name": "code",
      "type": "str",
      "description": "股票代码",
      "default_display": true
    },
    {
      "name": "freq",
      "type": "str",
      "description": "频度",
      "default_display": true
    },
    {
      "name": "time",
      "type": "str",
      "description": "交易时间",
      "default_display": true
    },
    {
      "name": "open",
      "type": "float",
      "description": "开盘价",
      "default_display": true
    },
    {
      "name": "close",
      "type": "float",
      "description": "收盘价",
      "default_display": true
    },
    {
      "name": "high",
      "type": "float",
      "description": "最高价",
      "default_display": true
    },
    {
      "name": "low",
      "type": "float",
      "description": "最低价",
      "default_display": true
    },
    {
      "name": "vol",
      "type": "int",
      "description": "成交量",
      "default_display": true
    },
    {
      "name": "amount",
      "type": "float",
      "description": "成交金额",
      "default_display": true
    },
    {
      "name": "oi",
      "type": "float",
      "description": "持仓量",
      "default_display": true
    }
  ]
}