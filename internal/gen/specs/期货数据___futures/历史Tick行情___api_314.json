      "default_display": false
    },
    {
      "name": "ask_price1",
      "type": "float64",
      "description": "卖一价",
      "default_display": false
    },
    {
      "name": "ask_volume1",
      "type": "float64",
      "description": "卖一量",
      "default_display": false
    },
    {
      "name": "open_interest",
      "type": "float64",
      "description": "持仓量",
      "default_display": true
    },
    {
      "name": "volume",
      "type": "float64",
