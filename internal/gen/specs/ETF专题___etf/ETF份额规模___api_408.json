  },
  "request_params": [
    {
      "name": "ts_code",
      "type": "str",
      "required": false,
      "description": "基金代码（可从ETF基础信息接口提取）"
    },
    {
      "name": "trade_date",
      "type": "str",
      "required": false,
      "description": "交易日期（YYYYMMDD格式）"
    },
    {
      "name": "start_date",
      "type": "str",
      "required": false,
      "description": "开始日期"
    },
    {
      "name": "end_date",
      "type": "str",
      "required": false,
      "description": "结束日期"
    },
    {
      "name": "exchange",
      "type": "str",
      "required": false,
      "description": "交易所（SSE上交所 SZSE深交所）"
    }
  ],
  "response_fields": [
    {
      "name": "trade_date",
      "type": "str",
      "default_display": true,
