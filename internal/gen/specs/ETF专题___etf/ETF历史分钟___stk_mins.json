      "description": "分钟频度（1min/5min/15min/30min/60min）",
      "required": true
    },
    {
      "name": "start_date",
      "type": "datetime",
      "description": "开始日期 格式：2025-06-01 09:00:00",
      "required": false
    },
    {
      "name": "end_date",
      "type": "datetime",
      "description": "结束时间 格式：2025-06-20 19:00:00",
      "required": false
    }
