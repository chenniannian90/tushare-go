{
  "api_name": "weekly",
  "description": "获取周线行情数据",
  "request_params": [
    {"name": "ts_code", "type": "string", "description": "股票代码"},
    {"name": "start_date", "type": "string", "description": "开始日期"},
    {"name": "end_date", "type": "string", "description": "结束日期"},
    {"name": "limit", "type": "string", "description": "单次返回数量"},
    {"name": "offset", "type": "string", "description": "偏移量"}
  ],
  "response_fields": [
    {"name": "ts_code", "type": "string", "description": "TS代码"},
    {"name": "trade_date", "type": "string", "description": "交易日期"},
    {"name": "open", "type": "float", "description": "开盘价"},
    {"name": "high", "type": "float", "description": "最高价"},
    {"name": "low", "type": "float", "description": "最低价"},
    {"name": "close", "type": "float", "description": "收盘价"},
    {"name": "vol", "type": "float", "description": "成交量（手）"},
    {"name": "amount", "type": "float", "description": "成交额（千元）"}
  ]
}
