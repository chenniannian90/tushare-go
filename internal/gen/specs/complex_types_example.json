{
  "api_name": "complex_example",
  "description": "Example API demonstrating complex/nested data types support",
  "request_params": [
    {
      "name": "ts_code",
      "type": "string",
      "description": "股票代码"
    },
    {
      "name": "start_date",
      "type": "string",
      "description": "开始日期"
    },
    {
      "name": "include_nested",
      "type": "bool",
      "description": "是否包含嵌套数据"
    }
  ],
  "response_fields": [
    {
      "name": "ts_code",
      "type": "string",
      "description": "股票代码"
    },
    {
      "name": "trade_date",
      "type": "string",
      "description": "交易日期"
    },
    {
      "name": "tags",
      "type": "array",
      "description": "标签数组",
      "items": {
        "name": "tag",
        "type": "string",
        "description": "单个标签"
      }
    },
    {
      "name": "scores",
      "type": "array",
      "description": "分数数组",
      "items": {
        "name": "score",
        "type": "float",
        "description": "单个分数"
      }
    },
    {
      "name": "metadata",
      "type": "object",
      "description": "元数据对象"
    },
    {
      "name": "close",
      "type": "float",
      "description": "收盘价"
    },
    {
      "name": "vol",
      "type": "float",
      "description": "成交量"
    }
  ]
}
